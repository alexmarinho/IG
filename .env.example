# LLM heuristic factory — OpenAI-compatible endpoint for `factory/evolve.py --backend llm`.
# Copy to .env and fill in your own key. This file is a template with NO secret in it.
# The default target is DeepSeek; any OpenAI-compatible API works (OpenAI, vLLM, Ollama, ...).

OPENAI_API_KEY=your-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
